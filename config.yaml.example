# 全局代理（可选，支持环境变量 HTTPS_PROXY/HTTP_PROXY 兜底）
proxy: "http://10.10.30.34:12821"

# 代理排除列表（可选，支持环境变量 NO_PROXY 兜底）
# 拉取镜像时使用代理，但推送到以下地址时不走代理
no_proxy: "hub.wiolfi.net,127.0.0.1,localhost"

# 同步行为
sync:
  retry: 3
  interval: 5s

# 同步规则 - 每条规则独立配置源和目标
# source 格式: registry/project/name
#   - Docker Hub: docker.io/library/alpine
#   - GHCR: ghcr.io/project/name
#   - registry.k8s.io: registry.k8s.io/project/name
#   - Quay: quay.io/project/name
rules:
  - name: "ubuntu"
    source: "docker.io/library/ubuntu"
    destination: "hub.wiolfi.net:23333/docker.io/ubuntu"
    proxy: true
    tags: ["22.04", "24.04"]

  - name: "alpine"
    source: "docker.io/library/alpine"
    destination: "hub.wiolfi.net:23333/docker.io/alpine"
    proxy: true
    tag_regex: '^\d+\.\d+(\.\d+)?$'

  - name: "coredns"
    source: "registry.k8s.io/coredns/coredns"
    destination: "hub.wiolfi.net:23333/registry.k8s.io/coredns/coredns"
    proxy: true
    tag_regex: '^v\d+\.\d+\.\d+$'

  - name: "pause"
    source: "registry.k8s.io/pause"
    destination: "hub.wiolfi.net:23333/registry.k8s.io/pause"
    proxy: true
    tags: ["3.9", "3.10"]

  - name: "operator"
    source: "quay.io/prometheus-operator/prometheus-operator"
    destination: "hub.wiolfi.net:23333/quay.io/prometheus-operator/prometheus-operator"
    proxy: true
    tag_regex: '^v\d+\.\d+\.\d+$'

  - name: "actions-runner"
    source: "ghcr.io/actions/actions-runner"
    destination: "hub.wiolfi.net:23333/ghcr.io/actions/actions-runner"
    proxy: true
    tags: ["2.321.0"]
